function w $fib(w %a) {
@bb0
	%c =w ceqw %a, 0
	%d =w ceqw %a, 1
	%e =w or %c, %d
	jnz %e, @bb1, @bb2

@bb1
	%b =w copy %a
	jmp @bb3

@bb2
	%g =w sub %a, 1
	%f =w call $fib(w %g)
	%i =w sub %a, 2
	%h =w call $fib(w %i)
	%j =w add %f, %h
	%b =w copy %j
	jmp @bb3

@bb3
	ret %b

}
export function w $main() {
@bb0
	%a =w call $fib(w 30)
	%b =w call $printf(l $fmt, ..., w %a)
	ret 0

}
data $fmt = {b "Result is %d", b 0}

